# ═══════════════════════════════════════════════════════════════════════

# antiphoria slop-research-factory — Environment Variables

# ═══════════════════════════════════════════════════════════════════════

# Copy this file to .env and fill in your API keys.

#

# SECURITY: .env is git-ignored.  Never commit secrets to the repo.

#

# Spec references: D-0 §4.1, D-4 §6, D-5 §11, D-8 §8.2

# ═══════════════════════════════════════════════════════════════════════


# ── LLM Provider Keys ────────────────────────────────────────────────

# OpenRouter — Generator + Reviser (deepseek/deepseek-r1)

# Obtain at: https://openrouter.ai/keys

OPENROUTER_API_KEY=

# Google AI — Verifier + Citation Extractor (google/gemini-2.5-flash)

# Obtain at: https://aistudio.google.com/apikey

GEMINI_API_KEY=


# ── Tool API Keys ────────────────────────────────────────────────────

# Semantic Scholar — citation metadata & abstract retrieval (D-4 §6.2)

# Free tier: 100 requests / 5 minutes

# Obtain at: https://www.semanticscholar.org/product/api#api-key

SEMANTIC_SCHOLAR_API_KEY=

# Tavily — web search for novelty checks & fact-grounding (D-4 §6.3)

# Obtain at: https://tavily.com/

TAVILY_API_KEY=


# ── Crossref (polite-pool contact, not a secret) ────────────────────

# Providing a mailto enables the Crossref "polite pool" (50 req/s).

# See: https://github.com/CrossRef/rest-api-doc#good-manners--more-data

CROSSREF_MAILTO=you@example.com


# ── Seal Engine ──────────────────────────────────────────────────────

# Path to the slop-cli binary.  Default: "slop-cli" (on $PATH).

# SLOP_CLI_PATH=slop-cli


# ── Provenance Safety Override (D-1 §10, D-5 §11) ───────────────────

#

# To disable provenance sealing you MUST set BOTH:

#   1. enabled = false   under [provenance] in antiphoria.toml

#   2. This environment variable set to "true"

#

# The verbose name is deliberate — it forces the operator to

# acknowledge the implications.  Silent one-click disable is

# forbidden (D-0 §8.2).

#

# ANTIPHORIA_I_UNDERSTAND_NO_PROVENANCE=true


# ── Development / Testing ────────────────────────────────────────────

# Override the prompt-file directory (default: <repo>/prompts/).

# ANTIPHORIA_PROMPTS_DIR=./prompts

# Run E2 integration tests against real APIs instead of fixtures.

# ANTIPHORIA_E2_REAL_API=false

# Log level: DEBUG, INFO (default), WARNING, ERROR, CRITICAL

# ANTIPHORIA_LOG_LEVEL=INFO


# ── Local Models (optional) ──────────────────────────────────────────

# Ollama base URL for local inference (e.g. ollama/deepseek-r1:32b).

# See D-0 §4.1 "Fallback/Local" row.

# OLLAMA_BASE_URL=http://localhost:11434